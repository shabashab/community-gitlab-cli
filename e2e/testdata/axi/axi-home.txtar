# Content-first home view: bare gl-axi shows tool identity plus live data -
# the project's open merge requests inside a repo, the authenticated user
# outside one. Never a help screen.

mkproject $SCRIPT_NAME-$RANDOM_STRING

exec git init repo
cd repo
exec git remote add origin $GL_E2E_HOST/$PROJECT.git
exec git commit --allow-empty -m init
exec git push -u origin main
exec git checkout -b feature
exec git add change.txt
exec git commit -m 'add change'
exec git push -u origin feature

retry gl-axi mr create --title 'E2E home view'
stdout2env IID 'iid: (\d+)'

# inside the repo: identity first, then the open merge requests
exec gl-axi
stdout 'bin: '
stdout 'description: '
stdout 'project: '$PROJECT
stdout 'merge_requests\[1\]\{iid,title,state,author\}:'
stdout 'E2E home view'
stdout 'total open'
! stderr .

# outside any repo: identity plus the authenticated user
cd $WORK
exec gl-axi
stdout 'bin: '
stdout 'description: '
stdout 'user:'
stdout 'username: '
! stderr .

-- repo/change.txt --
e2e home fixture content
